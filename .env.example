# sift environment — copy to .env and fill in for a live run.

# --- Local Nemotron rung (served by vLLM / llm-d / Featherless / NIM) ---
# Default endpoint is http://localhost:8000/v1/chat/completions (see providers.py "vllm").
# Point this at an llm-d gateway to fan the local tier across an idle-GPU fleet.
SIFT_LOCAL_ENDPOINT=http://localhost:8000/v1/chat/completions
NEMOTRON_MODEL=nvidia/Nemotron-Mini-4B-Instruct
SIFT_LOCAL_PORT=8000

# --- Claude ladder (haiku/sonnet/opus/fable rungs) ---
ANTHROPIC_API_KEY=

# --- Oracle containment (NemoClaw + OpenShell bounty) ---
# direct = plain subprocess (dev); openshell = run the oracle under the YAML policy.
SIFT_SANDBOX=direct
# SIFT_OPENSHELL_POLICY=policies/oracle.openshell.yaml
# OPENSHELL_BIN=openshell

# --- HiddenLayer runtime security (optional; enables I/O scanning) ---
# HIDDENLAYER_API_KEY=
# HIDDENLAYER_API_SECRET=
# HIDDENLAYER_ENDPOINT=

# --- Live run knobs ---
SIFT_ROUNDS=5
# SIFT_TASKS=tasks/dev_help_archetypes.json

# --- Fallback if local GPU serving is unavailable (Featherless $25 credit) ---
# Featherless is OpenAI-compatible; set SIFT_LOCAL_ENDPOINT to its URL and use an
# open model name in NEMOTRON_MODEL, or add a rung via sift.config.RungSpec.
# HUGGING_FACE_HUB_TOKEN=   # for gated Nemotron checkpoints
